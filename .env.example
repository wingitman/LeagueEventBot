# Discord Bot Configuration
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Database
# Path to the SQLite database file
DATABASE_PATH=./data/league.db

# Defaults
# Default rank for new players (bronze, silver, gold, platinum, diamond, champion, grandchampion, master)
DEFAULT_RANK=silver

# Logging
# Log level (info, debug, warn, error)
LOG_LEVEL=info

# Debug mode - enables verbose logging across all services
# Set to "true" to enable detailed debug logs
# WARNING: This produces a lot of output, only enable for troubleshooting
DEBUG=false

# Migrations path (for Docker deployments)
# Default: ./src/db/migrations
# MIGRATIONS_PATH=./src/db/migrations
